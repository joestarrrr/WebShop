<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebShop</title>

    @* Bootstrap CSS is loaded from wwwroot/lib/bootstrap (added by the template) *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebShop.styles.css" asp-append-version="true" />
</head>
<body>
    @*
        TOP NAVIGATION BAR
        asp-page="/Index" generates a link to Pages/Index.cshtml ("/")
        asp-area="Identity" links into the Identity UI area (login, register)
    *@
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container">
                @* Brand / logo link *@
                <a class="navbar-brand fw-bold" asp-area="" asp-page="/Index">&#128722; WebShop</a>

                @* Hamburger button for small screens *@
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    @* Left-side navigation links *@
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-page="/Products/Index">Products</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-page="/User/Orders">My Orders</a>
                            </li>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-page="/Admin/Orders">Admin Orders</a>
                            </li>
                        }
                    </ul>

                    @* Right-side: Login / Register (provided by Identity UI partial) *@
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    @* Main page content *@
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @* Footer *@
    <footer class="border-top footer text-muted mt-4">
        <div class="container py-2">
            &copy; 2026 - WebShop - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    @* JavaScript: jQuery and Bootstrap bundle (includes Popper.js) *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* Optional scripts section — individual pages can inject scripts here *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
