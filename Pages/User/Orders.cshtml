@page
@model WebShop.Pages.User.OrdersModel
@{
    ViewData["Title"] = "My Orders";
}

<h1 class="mb-3">My Orders</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

<div class="card mb-4">
    <div class="card-header">Current Cart</div>
    <div class="card-body">
        @if (Model.CartItems.Count == 0)
        {
            <p class="mb-0">Your cart is empty.</p>
        }
        else
        {
            <div class="table-responsive mb-3">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th class="text-end">Unit</th>
                            <th class="text-center">Qty</th>
                            <th class="text-end">Total</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.CartItems)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td class="text-end">@item.UnitPrice.ToString("0.00") kr</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">@item.LineTotal.ToString("0.00") kr</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <form method="post" asp-page-handler="DecreaseCartItem" class="d-inline">
                                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                            <button type="submit" class="btn btn-outline-secondary">-</button>
                                        </form>
                                        <form method="post" asp-page-handler="IncreaseCartItem" class="d-inline">
                                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                            <button type="submit" class="btn btn-outline-secondary">+</button>
                                        </form>
                                        <form method="post" asp-page-handler="RemoveCartItem" class="d-inline">
                                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                            <button type="submit" class="btn btn-outline-danger">Remove</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mb-3 text-end">
                <strong>
                    Cart total:
                    @Model.CartItems.Sum(i => i.LineTotal).ToString("0.00") kr
                </strong>
            </div>

            <form method="post" asp-page-handler="CreateOrder">
                <button type="submit" class="btn btn-primary">Create Order</button>
            </form>
        }
    </div>
</div>

<div class="card">
    <div class="card-header">Order History</div>
    <div class="card-body">
        @if (Model.Orders.Count == 0)
        {
            <p class="mb-0">No orders yet.</p>
        }
        else
        {
            @foreach (var order in Model.Orders)
            {
                <div class="border rounded p-3 mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <strong>Order #@order.Id</strong>
                        <span>@order.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                    </div>
                    <div class="mb-1">Status: <strong>@order.Status</strong></div>
                    <div class="mb-2">Total: <strong>@order.TotalAmount.ToString("0.00") kr</strong></div>
                    <ul class="mb-0">
                        @foreach (var item in order.Items)
                        {
                            <li>@item.ProductName x @item.Quantity - @item.LineTotal.ToString("0.00") kr</li>
                        }
                    </ul>
                </div>
            }
        }
    </div>
</div>
